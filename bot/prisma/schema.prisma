generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Reminder {
  id         String   @id @default(cuid())
  chatId     String
  text       String
  fireAt     DateTime
  timezone   String   @default("Europe/Amsterdam")
  recurrence String?
  fired      Boolean  @default(false)
  cancelled  Boolean  @default(false)
  bullJobId  String?
  createdAt  DateTime @default(now())

  @@index([chatId])
}

model ListItem {
  id        String   @id @default(cuid())
  chatId    String
  listName  String
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([chatId, listName, done])
}

model Memory {
  id        String   @id @default(cuid())
  chatId    String
  content   String
  tags      String[]
  createdAt DateTime @default(now())

  @@index([chatId])
}

model NodeType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
}

model RelationshipType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  fromTypes   String[]
  toTypes     String[]
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
}

model ReflectionLog {
  id        String   @id @default(cuid())
  summary   String
  changes   String
  createdAt DateTime @default(now())
}

model CalendarTokens {
  id           String   @id @default(cuid())
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

model UserSettings {
  id                      String @id @default(cuid())
  chatId                  String @unique
  calendarReminderMinutes Int    @default(5)
  morningBriefHour        Int    @default(8)
  eveningCheckInHour      Int    @default(21)
}

enum CommitmentStatus {
  pending
  completed
  missed
  rescheduled
  cancelled
}

enum GoalStatus {
  planning
  active
  paused
  completed
  abandoned
}

enum MilestoneStatus {
  pending
  completed
}

model Commitment {
  id        String           @id @default(cuid())
  chatId    String
  text      String
  deadline  DateTime
  status    CommitmentStatus @default(pending)
  bullJobId String?
  goalId    String?
  goal      Goal?            @relation(fields: [goalId], references: [id])
  createdAt DateTime         @default(now())

  @@index([chatId, status])
  @@index([chatId, deadline])
}

model Habit {
  id               String     @id @default(cuid())
  chatId           String
  text             String
  frequencyPerWeek Int
  active           Boolean    @default(true)
  goalId           String?
  goal             Goal?      @relation(fields: [goalId], references: [id])
  logs             HabitLog[]
  createdAt        DateTime   @default(now())

  @@index([chatId, active])
}

model HabitLog {
  id         String   @id @default(cuid())
  habitId    String
  date       DateTime
  completed  Boolean
  skipped    Boolean  @default(false)
  skipReason String?
  habit      Habit    @relation(fields: [habitId], references: [id])

  @@unique([habitId, date])
  @@index([habitId, date])
}

model Goal {
  id          String       @id @default(cuid())
  chatId      String
  title       String
  description String?
  status      GoalStatus   @default(planning)
  plan        Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  milestones  Milestone[]
  habits      Habit[]
  commitments Commitment[]

  @@index([chatId, status])
}

model Milestone {
  id          String          @id @default(cuid())
  goalId      String
  goal        Goal            @relation(fields: [goalId], references: [id])
  text        String
  targetDate  DateTime?
  status      MilestoneStatus @default(pending)
  completedAt DateTime?
  createdAt   DateTime        @default(now())

  @@index([goalId, status])
}
